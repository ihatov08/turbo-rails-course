<%= turbo_frame_tag lecture do %>
  <div class="p-4 border border-gray-200 rounded-lg bg-white">
    <div class="flex items-center justify-between">
      <span class="font-medium">
        <%= lecture.name %>
      </span>
      <div class="flex items-center gap-2">
        <%= link_to "編集", edit_admin_lecture_path(lecture), class: "rounded-md px-3 py-1.5 bg-gray-200 hover:bg-gray-300 text-sm font-medium" %>
        <%= button_to "削除", admin_lecture_path(lecture), method: :delete, class: "rounded-md px-3 py-1.5 text-white bg-red-600 hover:bg-red-500 text-sm font-medium cursor-pointer", data: { turbo_confirm: "本当に削除しますか？" } %>
      </div>
    </div>
  </div>
<% end %>
