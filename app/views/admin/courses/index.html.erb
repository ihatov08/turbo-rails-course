<div class="w-full">
  <div class="flex justify-between items-center">
    <h1 class="font-bold text-4xl">コース管理</h1>
    <%= link_to "コースを追加", new_admin_course_path, data: { turbo_frame: dom_id(Course.new) }, class: "rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white block font-medium" %>
  </div>

  <%= turbo_frame_tag Course.new do %>
    <% if @courses.empty? %>
      <div class="text-center py-24 border-2 border-dashed border-gray-300 rounded-lg mt-4">
        <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 10.5v6m3-3H9m4.06-7.19-2.12-2.12a1.5 1.5 0 0 0-1.061-.44H4.5A2.25 2.25 0 0 0 2.25 6v12a2.25 2.25 0 0 0 2.25 2.25h15A2.25 2.25 0 0 0 21.75 18V8.25a2.25 2.25 0 0 0-2.25-2.25h-5.379a1.5 1.5 0 0 1-1.06-.44Z" />
        </svg>
        <h3 class="mt-4 text-sm font-semibold text-gray-900">コースがまだありません</h3>
        <p class="mt-1 text-sm text-gray-500">新しいコースを作成して始めましょう。</p>
        <div class="mt-6">
          <%= link_to "コースを追加", new_admin_course_path, data: { turbo_frame: dom_id(Course.new) }, class: "rounded-md px-4 py-2.5 bg-blue-600 hover:bg-blue-500 text-white font-medium text-sm" %>
        </div>
      </div>
    <% end %>
  <% end %>

  <% @courses.each do |course| %>
    <%= render partial: "admin/courses/course", locals: { course: course } %>
  <% end %>
</div>
